{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Beskid Project Manifest",
  "scopeName": "source.beskid.proj",
  "patterns": [
    {
      "include": "#hash-comments"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#manifest-blocks"
    },
    {
      "include": "#manifest-field-keys"
    },
    {
      "include": "#manifest-enums"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "hash-comments": {
      "name": "comment.line.number-sign.beskid.proj",
      "match": "#[^\\n]*"
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.beskid.proj",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.beskid.proj"
            }
          },
          "end": "$"
        },
        {
          "name": "comment.block.beskid.proj",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.beskid.proj"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.beskid.proj"
            }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.beskid.proj",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.beskid.proj"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.beskid.proj"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.beskid.proj",
          "match": "\\\\(?:[nrt\\\"0]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\})"
        }
      ]
    },
    "manifest-blocks": {
      "name": "keyword.control.manifest.beskid.proj",
      "match": "\\b(?:project|target|dependency|workspace|member|override|registry)\\b"
    },
    "manifest-field-keys": {
      "name": "support.type.property-name.beskid.proj",
      "match": "\\b(?:name|version|root|root_namespace|kind|entry|source|path|url|rev|resolver)\\b"
    },
    "manifest-enums": {
      "name": "support.constant.manifest.beskid.proj",
      "match": "\\b(?:App|Lib|Test|path|git|registry|v1)\\b"
    },
    "numbers": {
      "name": "constant.numeric.beskid.proj",
      "match": "\\b(?:0[xX][0-9A-Fa-f_]+|0[bB][01_]+|0[oO][0-7_]+|[0-9][0-9_]*)\\b"
    }
  }
}
