{
  "name": "beskid-vscode",
  "displayName": "Beskid",
  "description": "Beskid language support for VS Code with bundled cross-platform LSP binaries and optional dev mode.",
  "version": "0.1.0",
  "publisher": "beskid",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cyber-Nomad-Collective/beskid.git"
  },
  "homepage": "https://beskid-lang.org",
  "bugs": {
    "url": "https://github.com/Cyber-Nomad-Collective/beskid/issues"
  },
  "keywords": [
    "beskid",
    "language-server",
    "lsp",
    "programming-language",
    "compiler"
  ],
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "main": "./out/extension.js",
  "packageManager": "bun@1.2.20",
  "contributes": {
    "commands": [
      {
        "command": "beskid.selectProject",
        "title": "Beskid: Select Project"
      },
      {
        "command": "beskid.lsp.quickActions",
        "title": "Beskid: LSP Quick Actions"
      },
      {
        "command": "beskid.lsp.start",
        "title": "Beskid: Start Language Server"
      },
      {
        "command": "beskid.lsp.stop",
        "title": "Beskid: Stop Language Server"
      },
      {
        "command": "beskid.lsp.restart",
        "title": "Beskid: Restart Language Server"
      },
      {
        "command": "beskid.packages.open",
        "title": "Beskid: Open Package Manager"
      },
      {
        "command": "beskid.packages.search",
        "title": "Beskid: Search Packages"
      },
      {
        "command": "beskid.packages.openRegistryUri",
        "title": "Beskid: Open registry URL"
      },
      {
        "command": "beskid.lsp.openLogs",
        "title": "Beskid: Open LSP Logs"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "beskid.selectProject"
        },
        {
          "command": "beskid.lsp.quickActions"
        },
        {
          "command": "beskid.lsp.start"
        },
        {
          "command": "beskid.lsp.stop"
        },
        {
          "command": "beskid.lsp.restart"
        },
        {
          "command": "beskid.packages.open"
        },
        {
          "command": "beskid.packages.search"
        },
        {
          "command": "beskid.lsp.openLogs"
        }
      ],
      "view/title": [
        {
          "command": "beskid.packages.search",
          "when": "view == beskidPackagesView",
          "group": "navigation"
        },
        {
          "command": "beskid.selectProject",
          "when": "view == beskidProjectOutlineView",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "beskidViews",
          "title": "Beskid",
          "icon": "media/beskid-logo.svg"
        }
      ]
    },
    "views": {
      "beskidViews": [
        {
          "id": "beskidPackagesView",
          "name": "Beskid Packages"
        },
        {
          "id": "beskidProjectOutlineView",
          "name": "Selected Project Outline"
        }
      ]
    },
    "languages": [
      {
        "id": "beskid",
        "aliases": [
          "Beskid",
          "beskid"
        ],
        "extensions": [
          ".bd"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "beskid-proj",
        "aliases": [
          "Beskid Project",
          "beskid-proj"
        ],
        "extensions": [
          ".proj"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "beskid",
        "scopeName": "source.beskid",
        "path": "./syntaxes/beskid.tmLanguage.json"
      },
      {
        "language": "beskid-proj",
        "scopeName": "source.beskid.proj",
        "path": "./syntaxes/beskid-proj.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Beskid LSP",
      "properties": {
        "beskid.lsp.server.command": {
          "type": "string",
          "default": "cargo",
          "description": "LSP launch command used in dev mode (requires `beskid.lsp.server.devMode=true`)."
        },
        "beskid.lsp.server.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "run",
            "-p",
            "beskid_lsp"
          ],
          "description": "LSP launch args used in dev mode (requires `beskid.lsp.server.devMode=true`)."
        },
        "beskid.lsp.server.preferBundled": {
          "type": "boolean",
          "default": true,
          "description": "Use bundled platform server binary under extension `server/<platform>-<arch>/`."
        },
        "beskid.lsp.server.devMode": {
          "type": "boolean",
          "default": false,
          "description": "Launch LSP from source (requires repo cloned locally). When false, extension expects bundled binary or explicit `server.path`."
        },
        "beskid.lsp.server.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a Beskid LSP binary. Overrides bundled and fallback command settings."
        },
        "beskid.lsp.server.cwd": {
          "type": "string",
          "default": "",
          "description": "Optional working directory for the language server process. Empty means current workspace root."
        },
        "beskid.lsp.server.debugArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "run",
            "-p",
            "beskid_lsp"
          ],
          "description": "Arguments used when VS Code launches the extension in debug mode (dev mode)."
        },
        "beskid.lsp.log.level": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info",
            "log",
            "debug"
          ],
          "default": "info",
          "description": "Language server log level routed to VS Code output."
        },
        "beskid.lsp.log.serverOutput": {
          "type": "boolean",
          "default": true,
          "description": "Mirror server output to the Beskid LSP output channel."
        },
        "beskid.pckg.baseUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Base URL of the pckg server used by the package manager pane."
        }
      }
    },
    "configurationDefaults": {
      "[beskid]": {
        "editor.defaultFormatter": "beskid.beskid-vscode"
      },
      "[beskid-proj]": {
        "editor.defaultFormatter": "beskid.beskid-vscode"
      }
    }
  },
  "scripts": {
    "sync:keywords": "bun scripts/sync-keywords.mjs",
    "build": "bunx tsc -p .",
    "watch": "bunx tsc -w -p .",
    "lint": "bunx tsc -p . --noEmit",
    "test:smoke:formatter": "node scripts/smoke-formatter.mjs",
    "package": "bunx @vscode/vsce package",
    "vscode:prepublish": "bun run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "3.17.5"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^25.3.1",
    "@types/vscode": "^1.88.0",
    "typescript": "^5.8.2"
  },
  "trustedDependencies": [
    "@vscode/vsce-sign"
  ]
}
