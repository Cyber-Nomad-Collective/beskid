---
import { getCollection } from 'astro:content';
import { docEntryHref, docEntrySlug, normalizeDocSlug } from './specSlug';

interface Props {
	/** Slug prefix without leading slash, e.g. platform-spec/compiler */
	pathPrefix: string;
	summaryTitle?: string;
}

const { pathPrefix, summaryTitle = 'Scope summary' } = Astro.props;
const base = normalizeDocSlug(pathPrefix);

const all = await getCollection('docs');

/** Descendants strictly under `base` (excludes the hub page at exactly `base`) */
const descendants = all.filter((e) => {
	const s = docEntrySlug(e);
	if (s === base) return false;
	return s.startsWith(`${base}/`);
});

const pageCount = descendants.length;

/** First segment of path under base */
const childKeys = new Set<string>();
for (const e of descendants) {
	const s = docEntrySlug(e);
	if (!s.startsWith(`${base}/`)) continue;
	const rest = s.slice(base.length + 1);
	const first = rest.split('/')[0];
	if (first) childKeys.add(first);
}

const sortedChildren = [...childKeys].sort();
---

<div class="platform-spec-hub">
	<h2>{summaryTitle}</h2>
	<ul class="platform-spec-hub__stats">
		<li><strong>{pageCount}</strong> page(s) under this subtree</li>
		<li><strong>{sortedChildren.length}</strong> direct child path segment(s)</li>
	</ul>
	{
		sortedChildren.length > 0 && (
			<>
				<h3>Child entries</h3>
				<ul class="platform-spec-hub__children">
					{sortedChildren.map((key) => {
						const entry =
							descendants.find((e) => docEntrySlug(e) === `${base}/${key}`) ??
							descendants.find((e) => docEntrySlug(e).startsWith(`${base}/${key}/`));
						const title = entry?.data.title ?? key;
						const slug = entry ? docEntrySlug(entry) : `${base}/${key}`;
						return (
							<li>
								<a href={docEntryHref(slug)}>{title}</a>
							</li>
						);
					})}
				</ul>
			</>
		)
	}
</div>
