---
import DomainTiles from './DomainTiles.astro';
import PlatformSpecGraphShell from './PlatformSpecGraphShell.astro';

/** Stable, route-scoped ids (unique per page if multiple hubs are ever embedded). */
const pathKey =
	Astro.url.pathname
		.replace(/\/+$/, '')
		.replace(/^\/+/, '')
		.replace(/\//g, '-') || 'root';
const uid = `psh-${pathKey.replace(/[^a-zA-Z0-9-]/g, '')}`;
const idTabMap = `${uid}-tab-map`;
const idTabBrowse = `${uid}-tab-browse`;
const idPanelMap = `${uid}-panel-map`;
const idPanelBrowse = `${uid}-panel-browse`;
---

<div class="platform-spec-home" data-platform-spec-home>
	<div class="platform-spec-home__toolbar" role="tablist" aria-label="Platform specification views">
		<button
			type="button"
			class="platform-spec-home__tab is-active"
			role="tab"
			id={idTabMap}
			aria-controls={idPanelMap}
			data-tab="map"
			aria-selected="true"
		>
			Map
		</button>
		<button
			type="button"
			class="platform-spec-home__tab"
			role="tab"
			id={idTabBrowse}
			aria-controls={idPanelBrowse}
			data-tab="browse"
			aria-selected="false"
			tabindex="-1"
		>
			Browse
		</button>
	</div>
	<div
		id={idPanelMap}
		class="platform-spec-home__panel"
		role="tabpanel"
		aria-labelledby={idTabMap}
		data-tab-panel="map"
	>
		<div class="platform-spec-map-page">
			<PlatformSpecGraphShell />
		</div>
	</div>
	<div
		id={idPanelBrowse}
		class="platform-spec-home__panel platform-spec-home__panel--browse"
		role="tabpanel"
		aria-labelledby={idTabBrowse}
		data-tab-panel="browse"
		hidden
	>
		<div class="platform-spec-home__browse-inner sl-markdown-content">
			<p class="platform-spec-home__lede">
				Explore the platform by domain, or use the <strong>Map</strong> tab for the interactive graph of areas
				and feature pages.
			</p>
			<DomainTiles pathPrefix="platform-spec" heading="Domains" />
		</div>
	</div>
</div>

<script>
	import '../client/platform-spec-home-tabs.ts';
</script>
