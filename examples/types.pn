type User {
    i32 id,
    string name,
}

type Point {
    i32 x,
    i32 y,
}

enum Option<T> {
    Some(T value),
    None,
}

User make_user(id: i32, name: string) {
    return User { id: id, name: name };
}

unit main(){
    User user = make_user(1, "John");
    std.io.println("User:");
    std.io.println(user.name);
}
